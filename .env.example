# Google Analytics 4 Measurement ID (get from analytics.google.com)
# Leave unset in dev to disable tracking locally
NEXT_PUBLIC_GA_ID=G-S6FQJ0BHJT

# Node environment
NODE_ENV=production

# Server port (Railway sets this automatically — do not set manually on Railway)
# PORT=9999

# SQLite database path
# On Railway: mount a Volume at /app/data and set this to /app/data/game.db
DATABASE_PATH=/app/data/game.db

# ── Issue Report Feature ──────────────────────────────────────────────────────
# Set to true to enable the floating report button and API route
ENABLE_REPORT=true

# Gmail SMTP (use an App Password — not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
REPORT_EMAIL_TO=dungtruong.server@gmail.com
