e:1.5rem;font-weight:800;color:var(--wolf);line-height:1;flex-shrink:0"},"2"],["DIV",{},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.3rem"},"Receive your secret role"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Each player privately views their role — Wolf or Villager. Don't show anyone your screen!"]]],["DIV",{"class":"panel","style":"display:flex;gap:1rem;align-items:flex-start"},["SPAN",{"style":"font-size:1.5rem;font-weight:800;color:var(--wolf);line-height:1;flex-shrink:0"},"3"],["DIV",{},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.3rem"},"Night Phase"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Wolves secretly vote to eliminate a Villager. Villagers wait with eyes closed."]]],["DIV",{"class":"panel","style":"display:flex;gap:1rem;align-items:flex-start"},["SPAN",{"style":"font-size:1.5rem;font-weight:800;color:var(--wolf);line-height:1;flex-shrink:0"},"4"],["DIV",{},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.3rem"},"Day Phase"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Everyone discusses who might be a Wolf. After the timer ends, players vote to eliminate one suspect."]]],["DIV",{"class":"panel","style":"display:flex;gap:1rem;align-items:flex-start"},["SPAN",{"style":"font-size:1.5rem;font-weight:800;color:var(--wolf);line-height:1;flex-shrink:0"},"5"],["DIV",{},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.3rem"},"Win the game"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Villagers win by eliminating all Wolves. Wolves win when they equal or outnumber the Villagers."]]]]]],["SECTION",{"style":"padding:3rem 1rem;border-top:1px solid var(--border);background:#fef2f2"},["DIV",{"class":"container"},["H2",{"style":"text-align:center;font-weight:800;font-size:1.5rem;margin-bottom:2rem"},"Roles Guide"],["DIV",{"style":"display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:1.25rem"},["DIV",{"class":"panel"},["DIV",{"style":"display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem"},["SPAN",{"style":"font-size:2rem"},"🐺"],["H3",{"style":"font-weight:800;font-size:1.1rem;color:#fca5a5"},"Wolf"]],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"Wolves know who their teammates are. Each night, wolves vote together to eliminate a villager. During the day, they must blend in and avoid suspicion."]],["DIV",{"class":"panel"},["DIV",{"style":"display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem"},["SPAN",{"style":"font-size:2rem"},"🏡"],["H3",{"style":"font-weight:800;font-size:1.1rem;color:#93c5fd"},"Villager"]],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"Villagers have no special abilities but outnumber the wolves at the start. Use logic, observation, and persuasion to identify and vote out the wolves."]]]]],["SECTION",{"style":"padding:3rem 1rem;border-top:1px solid var(--border)"},["DIV",{"class":"container"},["H2",{"style":"text-align:center;font-weight:800;font-size:1.5rem;margin-bottom:2rem"},"Strategy Tips"],["DIV",{"style":"display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:1.25rem"},["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.4rem"},"💡 ","Watch for inconsistencies"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Wolves often contradict themselves. Keep track of what everyone says across rounds."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.4rem"},"💡 ","Silence is suspicious"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"Players who say little and avoid taking a stance are often trying to stay under the radar."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.4rem"},"💡 ","Wolves should act natural"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"The best wolf players express genuine concern about finding wolves — without overdoing it."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:0.95rem;margin-bottom:0.4rem"},"💡 ","Use the vote strategically"],["P",{"style":"color:var(--text-muted);font-size:0.85rem;line-height:1.6"},"If you're a villager, never vote with zero reasoning. Share your logic to build trust and rally others."]]]]],["SECTION",{"style":"padding:3rem 1rem;border-top:1px solid var(--border)"},["DIV",{"class":"container","style":"max-width:680px"},["H2",{"style":"text-align:center;font-weight:800;font-size:1.5rem;margin-bottom:2rem"},"Frequently Asked Questions"],["DIV",{"style":"display:flex;flex-direction:column;gap:1rem"},["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"How many players does Werewolf need?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"The game works with as few as 3 players, but the ideal experience is 6–12. More players means more chaos, more deduction, and more fun."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"Do players need separate devices?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"Yes — each player needs their own phone or computer so they can receive their secret role privately. The game runs on any modern browser."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"How does the room code work?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"The host creates a room and gets a unique 6-character code. Share it via chat, voice call, or just read it aloud. Players enter it on the join screen."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"What happens if someone disconnects?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"The game state is saved on the server. If a player refreshes the page or reconnects with the same player ID, they rejoin their room automatically."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"Can the host change the number of wolves?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"Yes. The host can adjust the wolf count and discussion timer length in the Settings panel before starting the game."]],["DIV",{"class":"panel"},["H3",{"style":"font-weight:700;font-size:1rem;margin-bottom:0.4rem"},"Is Werewolf free to play?"],["P",{"style":"color:var(--text-muted);font-size:0.9rem;line-height:1.7"},"Completely free — no account, no downloads, no paywalls. Just create a room and share the code."]]]]],["SECTION",{"style":"padding:2.5rem 1rem;border-top:1px solid var(--border);text-align:center"},["DIV",{"class":"container"},["P",{"style":"color:var(--text-muted);margin-bottom:1rem"},"Looking for a different game?"],["A",{"class":"btn ghost","href":"/truthordare"},"🃏 Try Truth or Dare →"]]]],["FOOTER",{"class":"site-footer"},["P",{},["A",{"href":"/privacy"},"Privacy Policy"],"  ·  © 2025 Boardgame.sh"]],["NEXT-ROUTE-ANNOUNCER",{"style":"position: absolute;"},["template",{"__playwright_shadow_root_":"open"},["DIV",{"aria-live":"assertive","id":"__next-route-announcer__","role":"alert","style":"position: absolute; border: 0px; height: 1px; margin: -1px; padding: 0px; width: 1px; clip: rect(0px, 0px, 0px, 0px); overflow: hidden; white-space: nowrap; overflow-wrap: normal;"}]]],["INS",{"class":"adsbygoogle adsbygoogle-noablate","data-ad-hi":"true","data-adsbygoogle-status":"done","style":"display: none !important;"},["DIV",{"id":"aswift_0_host","style":"border: none; height: 0px; width: 0px; margin: 0px; padding: 0px; position: relative; visibility: visible; background-color: transparent; display: inline-block;"},["IFRAME",{"__play